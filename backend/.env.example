# =========================================================================
# AuditAgent backend — environment template.
# Copy to `.env` and fill in. NEVER commit the real `.env`.
# =========================================================================

# --- Supabase (server-side / trusted) ------------------------------------
# Project Settings -> API -> Project URL
SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co
# Project Settings -> API -> service_role key (SECRET, bypasses RLS)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# --- LLM (used in Phase 2) -----------------------------------------------
# https://aistudio.google.com/app/apikey  (free tier)
GOOGLE_API_KEY=your-google-ai-studio-key
# Model id — swap without code changes.
LLM_MODEL=gemini-1.5-flash

# --- App ------------------------------------------------------------------
# Comma-separated CORS allow-list of frontend origins.
FRONTEND_ORIGIN=http://localhost:3000
# 'development' | 'production'
APP_ENV=development

# GitHub App Integration
GITHUB_APP_ID=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_PRIVATE_KEY=

# AWS Integration (AssumeRole Platform User)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# --- Polar.sh (billing) ---------------------------------------------------
# Polar dashboard -> Settings -> API Keys (use a Sandbox token while testing).
POLAR_ACCESS_TOKEN=
POLAR_ORGANIZATION_ID=
# 'sandbox' while testing at sandbox.polar.sh, 'production' once you go live.
POLAR_SERVER=sandbox
# Polar dashboard -> Settings -> Webhooks -> (create endpoint) -> Secret.
# Required — without it the webhook endpoint refuses all requests rather
# than trusting an unverifiable payload.
POLAR_WEBHOOK_SECRET=
# Polar dashboard -> Products -> open each paid product -> copy its ID.
POLAR_PRODUCT_STARTER_ID=
POLAR_PRODUCT_GROWTH_ID=
